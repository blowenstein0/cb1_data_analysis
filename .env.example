# Backend: "bedrock" (default when no ANTHROPIC_API_KEY; uses AWS credentials
# from the environment/profile) or "anthropic" (direct API)
# CB1_BACKEND=bedrock
# CB1_AWS_REGION=us-east-1

# Only needed for the anthropic backend
# ANTHROPIC_API_KEY=sk-ant-...

# Hard-stop cap on cumulative API spend (USD)
CB1_BUDGET_CAP_USD=75

# Override the model for all LLM tiers
# CB1_MODEL=claude-haiku-4-5
